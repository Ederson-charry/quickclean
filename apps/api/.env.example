# Conexión a Postgres (docker compose up -d db). Puerto host local = 5544.
DATABASE_URL="postgresql://quickclean:localdev@localhost:5544/quickclean?schema=public"
# Puerto del API
PORT=3000
# Origen permitido para CORS (front)
WEB_ORIGIN="http://localhost:5173"
# Secreto para firmar el JWT de acceso (usar uno fuerte en prod, vía Secrets Manager)
JWT_SECRET="dev-only-change-me-in-prod"
# Cloudflare Turnstile (opcional en dev; si vacío, la verificación es no-op)
TURNSTILE_SECRET=""
# Clave para cifrar la semilla TOTP en reposo (AES-256-GCM). En prod: Secrets Manager.
MFA_ENC_KEY="dev-only-mfa-key-change-me"
