generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuditOutcome {
  success
  failure
  denied
}

enum TariffStatus {
  draft
  scheduled
  active
  expired
}

enum BookingStatus {
  agendado
  en_curso
  completado
  cancelado
}

enum EngagementType {
  contractor // prestación de servicios
  employee // contrato laboral directo
}

enum LeaveStatus {
  en_revision
  aprobada
  rechazada
}

/// Solicitud de ausencia del quicker (incapacidad/licencia/vacaciones). Insumo de
/// disponibilidad para el ranking de asignación.
model LeaveRequest {
  id           String      @id @default(uuid())
  quickerId    String
  quicker      Quicker     @relation(fields: [quickerId], references: [id], onDelete: Cascade)
  kind         String // incapacidad | licencia | vacaciones
  startDate    DateTime
  endDate      DateTime
  reason       String?
  status       LeaveStatus @default(en_revision)
  createdAt    DateTime    @default(now())
  reviewedById String?
  reviewedAt   DateTime?

  @@index([quickerId])
  @@index([status])
}

/// Perfil del cliente. `empresa` exige contratación directa (solidaridad laboral, §6).
model Client {
  id                 String         @id @default(uuid())
  userId             String         @unique
  user               User           @relation("UserClient", fields: [userId], references: [id], onDelete: Cascade)
  name               String
  kind               String         @default("persona") // persona | empresa
  docType            String? // cc | nit | ce | pasaporte
  docNumber          String?
  requiresDirectHire Boolean        @default(false)
  createdAt          DateTime       @default(now())
  contracts          WorkContract[]
}

/// Relación de trabajo quicker↔cliente (o pool si clientId null). El régimen
/// depende de la relación con el cliente, no solo del quicker (§6.1).
model WorkContract {
  id             String         @id @default(uuid())
  quickerId      String
  quicker        Quicker        @relation(fields: [quickerId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?        @relation(fields: [clientId], references: [id])
  engagementType EngagementType
  position       String?
  contractKind   String         @default("prestacion") // prestacion | fijo | indefinido
  /// Salario base mensual (COP). Requerido para liquidar nómina de un employee.
  monthlySalary  Int?
  status         String         @default("activo") // activo | finalizado
  startDate      DateTime       @default(now())
  endDate        DateTime?
  createdAt      DateTime       @default(now())
  payrollRuns    PayrollRun[]

  @@index([quickerId])
  @@index([clientId])
}

/// Liquidación de nómina de un employee por período (conceptos CST). QuickClean es
/// system-of-record; el ERP/GAF emite el pago real. Guarda snapshot del cálculo.
model PayrollRun {
  id                String       @id @default(uuid())
  contractId        String
  contract          WorkContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  quickerId         String // denormalizado para listar
  periodFrom        DateTime
  periodTo          DateTime
  baseSalary        Int // salario base prorrateado (IBC)
  transportAllowance Int // auxilio de transporte
  bonuses           Int // suma de bonos (devengo extra)
  grossEarnings     Int // total devengado
  healthDeduction   Int // aporte salud empleado (4%)
  pensionDeduction  Int // aporte pensión empleado (4%)
  otherDeductions   Int // otras deducciones
  totalDeductions   Int
  netPay            Int // neto a pagar
  items             Json // detalle de líneas {concepto, tipo, monto}
  status            String       @default("calculada") // calculada | pagada
  createdById       String
  createdAt         DateTime     @default(now())
  paidAt            DateTime?

  @@index([contractId])
  @@index([quickerId])
  @@index([status])
}

/// Perfil operativo del quicker (vinculado a un User con rol quicker).
model Quicker {
  id          String              @id @default(uuid())
  userId      String              @unique
  user        User                @relation("UserQuicker", fields: [userId], references: [id], onDelete: Cascade)
  name        String
  zone        String
  rating      Float               @default(5)
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  skills        QuickerSkill[]
  assignments   ServiceAssignment[]
  payouts       Payout[]
  contracts     WorkContract[]
  leaveRequests LeaveRequest[]

  @@index([active])
}

/// Capacidad del quicker por categoría de servicio (gap del modelo, spec §8.1).
model QuickerSkill {
  id                String          @id @default(uuid())
  quickerId         String
  quicker           Quicker         @relation(fields: [quickerId], references: [id], onDelete: Cascade)
  serviceCategoryId String
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id])
  level             Int?

  @@unique([quickerId, serviceCategoryId])
  @@index([serviceCategoryId])
}

/// Liquidación (cuenta de cobro) de un quicker: agrega el payout de sus
/// servicios completados. QuickClean es system-of-record; GAF/ERP emite nómina.
model Payout {
  id           String    @id @default(uuid())
  quickerId    String
  quicker      Quicker   @relation(fields: [quickerId], references: [id])
  amount       Int
  bookingCount Int
  status       String    @default("pendiente") // pendiente | pagado
  periodFrom   DateTime?
  periodTo     DateTime?
  createdById  String
  createdAt    DateTime  @default(now())
  paidAt       DateTime?
  bookings     Booking[]

  @@index([quickerId])
  @@index([status])
}

/// Asignación de un quicker a una reserva (salida de la Torre de Control).
model ServiceAssignment {
  id           String   @id @default(uuid())
  bookingId    String   @unique
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  quickerId    String
  quicker      Quicker  @relation(fields: [quickerId], references: [id])
  assignedById String
  assignedAt   DateTime @default(now())
  reason       String?

  @@index([quickerId])
}

/// Reserva de servicio. Guarda snapshot de tariffId y del precio calculado:
/// aunque la tarifa cambie/expire después, la reserva conserva su precio.
model Booking {
  id                String          @id @default(uuid())
  clientId          String
  client            User            @relation("BookingClient", fields: [clientId], references: [id])
  serviceCategoryId String
  category          ServiceCategory @relation(fields: [serviceCategoryId], references: [id])
  tariffId          String
  tariff            Tariff          @relation(fields: [tariffId], references: [id])
  duration          Int
  frequency         String
  size              String
  supplies          Boolean         @default(false)
  scheduledAt       DateTime
  address           String
  notes             String?
  pets              Boolean         @default(false)
  priceLabor        Int
  priceTotal        Int
  payout            Int
  status            BookingStatus   @default(agendado)
  quickerId         String?
  quicker           User?           @relation("BookingQuicker", fields: [quickerId], references: [id])
  ratedAt           DateTime?
  rating            Int?
  ratingComment     String?
  createdAt         DateTime        @default(now())
  assignment        ServiceAssignment?
  payoutId          String?
  payoutLiquidation Payout?         @relation(fields: [payoutId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([serviceCategoryId])
}

/// Catálogo dinámico de servicios (reemplaza el enum fijo ServiceType).
model ServiceCategory {
  id          String    @id @default(uuid())
  slug        String    @unique
  name        String
  description String?
  iconName    String // nombre del icono lucide-react
  colorToken  String // token de color de marca (ej. brand-600)
  active      Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  archivedAt    DateTime?
  tariffs       Tariff[]
  bookings      Booking[]
  quickerSkills QuickerSkill[]

  @@index([active])
}

/// Tarifa versionada: nunca se edita en sitio; publicar = nueva versión que
/// cierra la anterior (effectiveTo). Las reservas guardan snapshot de tariffId.
model Tariff {
  id                String          @id @default(uuid())
  serviceCategoryId String
  category          ServiceCategory @relation(fields: [serviceCategoryId], references: [id])
  name              String
  effectiveFrom     DateTime
  effectiveTo       DateTime?
  status            TariffStatus    @default(draft)
  publishedBy       String?
  publishedAt       DateTime?
  createdAt         DateTime        @default(now())
  rules             TariffRule[]
  bookings          Booking[]

  @@index([serviceCategoryId])
  @@index([status])
}

/// Regla de precio de una tarifa (dimensión + clave + modificador).
model TariffRule {
  id           String @id @default(uuid())
  tariffId     String
  tariff       Tariff @relation(fields: [tariffId], references: [id], onDelete: Cascade)
  dimension    String // duration|frequency|size|supplies|platform_fee|payout_pct
  key          String // clave dentro de la dimensión ("4", "semanal", "M"); "" para escalares
  modifierType String // base|percent|multiplier|flat
  value        Float

  @@index([tariffId])
}

/// Bitácora de auditoría append-only y encadenada por hash (tamper-evident).
/// UPDATE/DELETE bloqueados por trigger a nivel Postgres (ver migración audit_immutability).
model AuditLog {
  id           String       @id @default(uuid())
  seq          BigInt       @unique @default(autoincrement())
  occurredAt   DateTime     @default(now())
  actorId      String?
  actorRole    String?
  action       String
  resourceType String?
  resourceId   String?
  outcome      AuditOutcome
  ip           String?
  userAgent    String?
  before       Json?
  after        Json?
  metadata     Json?
  requestId    String?
  hashPrev     String
  hashSelf     String       @unique

  @@index([occurredAt])
  @@index([actorId])
  @@index([action])
  @@index([outcome])
}

enum UserStatus {
  active
  locked
  inactive
  suspended
  pending_verification
}

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  phone            String?
  status           UserStatus @default(pending_verification)
  emailVerifiedAt  DateTime?
  phoneVerifiedAt  DateTime?
  lastActivityAt   DateTime   @default(now())
  failedLoginCount Int        @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime   @default(now())
  /// Marca de supresión (Ley 1581): PII anonimizada, registros con retención legal conservados.
  deletedAt        DateTime?

  credential      Credential?
  passwordHistory PasswordHistory[]
  sessions        Session[]
  mfaFactors      MfaFactor[]
  recoveryCodes   RecoveryCode[]
  resetTokens     PasswordResetToken[]
  notifications   Notification[]
  consents        Consent[]
  roles           UserRole[]
  bookingsAsClient  Booking[] @relation("BookingClient")
  bookingsAsQuicker Booking[] @relation("BookingQuicker")
  quickerProfile    Quicker?  @relation("UserQuicker")
  clientProfile     Client?   @relation("UserClient")
}

/// Token de un solo uso para restablecer contraseña. Se guarda solo el hash
/// (SHA-256) del token enviado; expira y se invalida al usarse.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Consentimiento de tratamiento de datos (Habeas Data, Ley 1581). Registro de la
/// aceptación de una versión de la política; se puede retirar (withdrawnAt).
model Consent {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  policyVersion String
  acceptedAt    DateTime  @default(now())
  ip            String?
  withdrawnAt   DateTime?

  @@index([userId])
}

/// Bandeja de salida de notificaciones (email/SMS). Registro auditable de cada
/// mensaje; el transporte real se conecta por entorno (SMTP/SMS) sin acoplar dominio.
model Notification {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel   String // email | sms
  to        String
  kind      String // welcome | password_reset | booking_confirmed
  subject   String
  body      String
  status    String   @default("sent") // sent | failed
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([kind])
  @@index([createdAt])
}

model Credential {
  userId             String   @id
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash       String
  passwordChangedAt  DateTime @default(now())
  mustChangePassword Boolean  @default(false)
}

model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Session {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  familyId         String
  ip               String?
  userAgent        String?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  @@index([userId])
  @@index([familyId])
}

model MfaFactor {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // "totp" | "sms"
  secret      String // cifrado en reposo (AES-256-GCM)
  confirmedAt DateTime?
  isDefault   Boolean   @default(false)
  lastUsedStep BigInt?  // último paso TOTP consumido (anti-replay)

  @@index([userId])
}

model RecoveryCode {
  id       String    @id @default(uuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash String
  usedAt   DateTime?

  @@index([userId])
}

model Role {
  id          String           @id @default(uuid())
  key         String           @unique // super_admin|ops|finance|auditor|quicker|client
  name        String
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id    String           @id @default(uuid())
  key   String           @unique // ej. service.update, tariff.assign, audit.read
  roles RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}
