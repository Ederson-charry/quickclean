generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuditOutcome {
  success
  failure
  denied
}

enum TariffStatus {
  draft
  scheduled
  active
  expired
}

enum BookingStatus {
  agendado
  en_curso
  completado
  cancelado
}

/// Perfil operativo del quicker (vinculado a un User con rol quicker).
model Quicker {
  id          String              @id @default(uuid())
  userId      String              @unique
  user        User                @relation("UserQuicker", fields: [userId], references: [id], onDelete: Cascade)
  name        String
  zone        String
  rating      Float               @default(5)
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  skills      QuickerSkill[]
  assignments ServiceAssignment[]
  payouts     Payout[]

  @@index([active])
}

/// Capacidad del quicker por categoría de servicio (gap del modelo, spec §8.1).
model QuickerSkill {
  id                String          @id @default(uuid())
  quickerId         String
  quicker           Quicker         @relation(fields: [quickerId], references: [id], onDelete: Cascade)
  serviceCategoryId String
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id])
  level             Int?

  @@unique([quickerId, serviceCategoryId])
  @@index([serviceCategoryId])
}

/// Liquidación (cuenta de cobro) de un quicker: agrega el payout de sus
/// servicios completados. QuickClean es system-of-record; GAF/ERP emite nómina.
model Payout {
  id           String    @id @default(uuid())
  quickerId    String
  quicker      Quicker   @relation(fields: [quickerId], references: [id])
  amount       Int
  bookingCount Int
  status       String    @default("pendiente") // pendiente | pagado
  periodFrom   DateTime?
  periodTo     DateTime?
  createdById  String
  createdAt    DateTime  @default(now())
  paidAt       DateTime?
  bookings     Booking[]

  @@index([quickerId])
  @@index([status])
}

/// Asignación de un quicker a una reserva (salida de la Torre de Control).
model ServiceAssignment {
  id           String   @id @default(uuid())
  bookingId    String   @unique
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  quickerId    String
  quicker      Quicker  @relation(fields: [quickerId], references: [id])
  assignedById String
  assignedAt   DateTime @default(now())
  reason       String?

  @@index([quickerId])
}

/// Reserva de servicio. Guarda snapshot de tariffId y del precio calculado:
/// aunque la tarifa cambie/expire después, la reserva conserva su precio.
model Booking {
  id                String          @id @default(uuid())
  clientId          String
  client            User            @relation("BookingClient", fields: [clientId], references: [id])
  serviceCategoryId String
  category          ServiceCategory @relation(fields: [serviceCategoryId], references: [id])
  tariffId          String
  tariff            Tariff          @relation(fields: [tariffId], references: [id])
  duration          Int
  frequency         String
  size              String
  supplies          Boolean         @default(false)
  scheduledAt       DateTime
  address           String
  notes             String?
  pets              Boolean         @default(false)
  priceLabor        Int
  priceTotal        Int
  payout            Int
  status            BookingStatus   @default(agendado)
  quickerId         String?
  quicker           User?           @relation("BookingQuicker", fields: [quickerId], references: [id])
  ratedAt           DateTime?
  rating            Int?
  ratingComment     String?
  createdAt         DateTime        @default(now())
  assignment        ServiceAssignment?
  payoutId          String?
  payoutLiquidation Payout?         @relation(fields: [payoutId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([serviceCategoryId])
}

/// Catálogo dinámico de servicios (reemplaza el enum fijo ServiceType).
model ServiceCategory {
  id          String    @id @default(uuid())
  slug        String    @unique
  name        String
  description String?
  iconName    String // nombre del icono lucide-react
  colorToken  String // token de color de marca (ej. brand-600)
  active      Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  archivedAt    DateTime?
  tariffs       Tariff[]
  bookings      Booking[]
  quickerSkills QuickerSkill[]

  @@index([active])
}

/// Tarifa versionada: nunca se edita en sitio; publicar = nueva versión que
/// cierra la anterior (effectiveTo). Las reservas guardan snapshot de tariffId.
model Tariff {
  id                String          @id @default(uuid())
  serviceCategoryId String
  category          ServiceCategory @relation(fields: [serviceCategoryId], references: [id])
  name              String
  effectiveFrom     DateTime
  effectiveTo       DateTime?
  status            TariffStatus    @default(draft)
  publishedBy       String?
  publishedAt       DateTime?
  createdAt         DateTime        @default(now())
  rules             TariffRule[]
  bookings          Booking[]

  @@index([serviceCategoryId])
  @@index([status])
}

/// Regla de precio de una tarifa (dimensión + clave + modificador).
model TariffRule {
  id           String @id @default(uuid())
  tariffId     String
  tariff       Tariff @relation(fields: [tariffId], references: [id], onDelete: Cascade)
  dimension    String // duration|frequency|size|supplies|platform_fee|payout_pct
  key          String // clave dentro de la dimensión ("4", "semanal", "M"); "" para escalares
  modifierType String // base|percent|multiplier|flat
  value        Float

  @@index([tariffId])
}

/// Bitácora de auditoría append-only y encadenada por hash (tamper-evident).
/// UPDATE/DELETE bloqueados por trigger a nivel Postgres (ver migración audit_immutability).
model AuditLog {
  id           String       @id @default(uuid())
  seq          BigInt       @unique @default(autoincrement())
  occurredAt   DateTime     @default(now())
  actorId      String?
  actorRole    String?
  action       String
  resourceType String?
  resourceId   String?
  outcome      AuditOutcome
  ip           String?
  userAgent    String?
  before       Json?
  after        Json?
  metadata     Json?
  requestId    String?
  hashPrev     String
  hashSelf     String       @unique

  @@index([occurredAt])
  @@index([actorId])
  @@index([action])
  @@index([outcome])
}

enum UserStatus {
  active
  locked
  inactive
  suspended
  pending_verification
}

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  phone            String?
  status           UserStatus @default(pending_verification)
  emailVerifiedAt  DateTime?
  phoneVerifiedAt  DateTime?
  lastActivityAt   DateTime   @default(now())
  failedLoginCount Int        @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime   @default(now())

  credential      Credential?
  passwordHistory PasswordHistory[]
  sessions        Session[]
  mfaFactors      MfaFactor[]
  recoveryCodes   RecoveryCode[]
  roles           UserRole[]
  bookingsAsClient  Booking[] @relation("BookingClient")
  bookingsAsQuicker Booking[] @relation("BookingQuicker")
  quickerProfile    Quicker?  @relation("UserQuicker")
}

model Credential {
  userId             String   @id
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash       String
  passwordChangedAt  DateTime @default(now())
  mustChangePassword Boolean  @default(false)
}

model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Session {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  familyId         String
  ip               String?
  userAgent        String?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  @@index([userId])
  @@index([familyId])
}

model MfaFactor {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // "totp" | "sms"
  secret      String // cifrado en reposo (AES-256-GCM)
  confirmedAt DateTime?
  isDefault   Boolean   @default(false)
  lastUsedStep BigInt?  // último paso TOTP consumido (anti-replay)

  @@index([userId])
}

model RecoveryCode {
  id       String    @id @default(uuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash String
  usedAt   DateTime?

  @@index([userId])
}

model Role {
  id          String           @id @default(uuid())
  key         String           @unique // super_admin|ops|finance|auditor|quicker|client
  name        String
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id    String           @id @default(uuid())
  key   String           @unique // ej. service.update, tariff.assign, audit.read
  roles RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}
